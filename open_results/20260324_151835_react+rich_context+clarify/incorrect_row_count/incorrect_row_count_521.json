  "pred_sql": "WITH artist_counts AS (\n  SELECT artist, COUNT(*) as card_count\n  FROM cards\n  WHERE artist IS NOT NULL\n  GROUP BY artist\n),\nmin_count AS (\n  SELECT MIN(card_count) as min_val\n  FROM artist_counts\n),\nmin_artists AS (\n  SELECT artist\n  FROM artist_counts\n  WHERE card_count = (SELECT min_val FROM min_count)\n)\nSELECT c.artist, l.format\nFROM cards c\nJOIN legalities l ON c.uuid = l.uuid\nWHERE c.artist IN (SELECT artist FROM min_artists)\nORDER BY c.artist, l.format;",
